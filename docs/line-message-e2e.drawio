        <mxCell id="rdecision" value="RouteDecision&#xa;action + intent + confidence + source&#xa;+ resolvedQuery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;" vertex="1" parent="r1"><mxGeometry x="1190" y="330" width="290" height="100" as="geometry"/></mxCell>
