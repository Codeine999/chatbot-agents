        <mxCell id="queue" value="Redis / BullMQ&#xa;line-events queue&#xa;attempts=3, exponential backoff" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="710" y="130" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="worker" value="LineEventsProcessor.process&#xa;concurrency=7; limiter=12/sec" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="705" y="280" width="250" height="75" as="geometry"/></mxCell>
        <mxCell id="map" value="userProcessingTails Map&#xa;serialize same user in this process&#xa;different users remain concurrent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="690" y="400" width="280" height="90" as="geometry"/></mxCell>
