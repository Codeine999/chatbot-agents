        <mxCell id="rcancel" value="CANCEL_SESSION&#xa;clear session + cancelled template&#xa;RULE / CLEAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="r1"><mxGeometry x="40" y="720" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="rregister" value="START/CONTINUE_REGISTER&#xa;RegistrationFlowService&#xa;Redis session + Member DB&#xa;REGISTRATION / CLEAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="r1"><mxGeometry x="310" y="710" width="260" height="110" as="geometry"/></mxCell>
