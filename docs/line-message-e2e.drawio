        <mxCell id="guard" value="LineSignatureGuard&#xa;HMAC-SHA256 + timingSafeEqual" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="355" y="235" width="200" height="100" as="geometry"/></mxCell>
