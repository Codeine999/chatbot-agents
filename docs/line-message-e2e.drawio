        <mxCell id="release" value="on throw before successful reply:&#xa;release DB claim + BullMQ retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="700" y="1290" width="260" height="75" as="geometry"/></mxCell>

