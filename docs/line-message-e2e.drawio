  <diagram id="data-erd" name="3 - Data and Redis ERD">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="d0"/>
        <mxCell id="d1" parent="d0"/>
        <mxCell id="dtitle" value="Data model used by LINE message flow" style="text;html=1;fontSize=24;fontStyle=1;align=left;" vertex="1" parent="d1"><mxGeometry x="20" y="20" width="900" height="40" as="geometry"/></mxCell>
        <mxCell id="dpg" value="PostgreSQL / Prisma" style="swimlane;html=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="d1"><mxGeometry x="20" y="80" width="1530" height="1250" as="geometry"/></mxCell>
        <mxCell id="dredis" value="Redis (state/cache/limits/queue; not relational)" style="swimlane;html=1;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="d1"><mxGeometry x="1580" y="80" width="560" height="1250" as="geometry"/></mxCell>

        <mxCell id="dmember" value="&lt;b&gt;Member&lt;/b&gt;&#xa;PK uuid&#xa;UK username, phone, banknumber&#xa;password bcrypt hash" style="swimlane;html=1;startSize=28;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="d1"><mxGeometry x="80" y="170" width="250" height="140" as="geometry"/></mxCell>
        <mxCell id="dlmember" value="&lt;b&gt;LineMember&lt;/b&gt;&#xa;PK id&#xa;FK memberId nullable&#xa;UK lineUserId&#xa;displayName/profile&#xa;lastActiveAt" style="swimlane;html=1;startSize=28;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="d1"><mxGeometry x="410" y="150" width="260" height="180" as="geometry"/></mxCell>
        <mxCell id="dconv" value="&lt;b&gt;LineConversation&lt;/b&gt;&#xa;PK id&#xa;FK+UK lineMemberId (1:1)&#xa;status&#xa;lastMessage/type/time&#xa;unreadCount" style="swimlane;html=1;startSize=28;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="d1"><mxGeometry x="760" y="140" width="280" height="200" as="geometry"/></mxCell>
        <mxCell id="dhistory" value="&lt;b&gt;LineChatHistory&lt;/b&gt;&#xa;PK id&#xa;FK conversationId&#xa;FK lineMemberId&#xa;sender / messageType / text&#xa;lineMessageId (indexed, not unique)&#xa;replyToken / rawEvent / sentStatus" style="swimlane;html=1;startSize=28;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="d1"><mxGeometry x="1130" y="120" width="330" height="240" as="geometry"/></mxCell>
        <mxCell id="dclaim" value="&lt;b&gt;ProcessedLineWebhookEvent&lt;/b&gt;&#xa;PK id&#xa;UK webhookEventId&#xa;processedAt&#xa;&#xa;Standalone idempotency claim" style="swimlane;html=1;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="d1"><mxGeometry x="80" y="480" width="300" height="170" as="geometry"/></mxCell>
        <mxCell id="dsetting" value="&lt;b&gt;AiSetting&lt;/b&gt;&#xa;PK id&#xa;systemPrompt&#xa;tone&#xa;fallbackMessage&#xa;active" style="swimlane;html=1;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="d1"><mxGeometry x="470" y="480" width="240" height="180" as="geometry"/></mxCell>
        <mxCell id="dpattern" value="&lt;b&gt;AnswerPattern&lt;/b&gt;&#xa;PK id&#xa;title / description / category&#xa;intentKey / keywords / examples&#xa;answer / priority / active" style="swimlane;html=1;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="d1"><mxGeometry x="810" y="460" width="290" height="210" as="geometry"/></mxCell>
        <mxCell id="dvector" value="&lt;b&gt;AnswerPatternVector&lt;/b&gt;&#xa;PK id&#xa;FK+UK answerPatternId&#xa;embedding vector&#xa;embeddingModel / active&#xa;&#xa;Current search path does not query it" style="swimlane;html=1;startSize=28;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="d1"><mxGeometry x="1190" y="450" width="290" height="230" as="geometry"/></mxCell>
        <mxCell id="dnote" value="Inbound transaction:&#xa;LineConversation upsert + USER LineChatHistory insert + LineMember.lastActiveAt update&#xa;&#xa;Outbound transaction:&#xa;SYSTEM LineChatHistory insert + LineConversation preview update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="d1"><mxGeometry x="420" y="810" width="690" height="150" as="geometry"/></mxCell>
        <mxCell id="drisk" value="Retry caveat: inbound may already be committed before a later failure releases the claim. Because lineMessageId is not unique, retry can duplicate USER history/unread increment." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="d1"><mxGeometry x="420" y="1030" width="690" height="110" as="geometry"/></mxCell>

        <mxCell id="dbull" value="&lt;b&gt;BullMQ keys&lt;/b&gt;&#xa;line-events jobs&#xa;attempts/backoff/retention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="d1"><mxGeometry x="1660" y="150" width="390" height="90" as="geometry"/></mxCell>
        <mxCell id="drate" value="&lt;b&gt;Rate-limit keys&lt;/b&gt;&#xa;rl:line:global:ingress&#xa;rl:line:global:reply&#xa;rl:line:user:*&#xa;rl:ai:*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="d1"><mxGeometry x="1660" y="290" width="390" height="120" as="geometry"/></mxCell>
        <mxCell id="dabuse" value="&lt;b&gt;Abuse keys&lt;/b&gt;&#xa;ban:line:user:*&#xa;strikes:line:user:*&#xa;spam:line:user:*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="d1"><mxGeometry x="1660" y="460" width="390" height="105" as="geometry"/></mxCell>
        <mxCell id="dsession" value="&lt;b&gt;chat:session:userId&lt;/b&gt;&#xa;REGISTER / GENERAL_QUESTION / CONTACT_ADMIN state&#xa;sliding TTL default 30m" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="d1"><mxGeometry x="1660" y="620" width="390" height="110" as="geometry"/></mxCell>
        <mxCell id="dcontext" value="&lt;b&gt;chat:context:conversationId&lt;/b&gt;&#xa;Redis list of max 3 complete turns&#xa;Q/A redacted; TTL 30m&#xa;used only as AI conversational context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="d1"><mxGeometry x="1660" y="790" width="390" height="120" as="geometry"/></mxCell>
        <mxCell id="dmap" value="&lt;b&gt;Process RAM (not Redis)&lt;/b&gt;&#xa;userProcessingTails Map&#xa;orders same-user jobs on this single server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="d1"><mxGeometry x="1660" y="980" width="390" height="105" as="geometry"/></mxCell>
        <mxCell id="dnolock" value="No chat processing distributed lock. Redis is still used for queue, sessions, context, limits and abuse state." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="d1"><mxGeometry x="1660" y="1140" width="390" height="100" as="geometry"/></mxCell>

