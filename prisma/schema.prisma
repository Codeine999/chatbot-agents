// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PaymentType {
  QRcode
  Slip
}

enum PaymentStatus {
  pending
  success
  fail
  reject
}

enum CreditWalletType {
  LINE_MESSAGE
  AI_USAGE
  ADMIN_AI_QUERY
}

enum LineChatSender {
  USER   @map("user")
  ADMIN  @map("admin")
  AI     @map("ai")
  SYSTEM @map("system")
}

enum LineChatMessageType {
  TEXT     @map("text")
  IMAGE    @map("image")
  STICKER  @map("sticker")
  POSTBACK @map("postback")
}

model Member {
  uuid          String       @id @default(uuid()) @db.Uuid
  username      String       @unique
  password      String
  firstname     String
  lastname      String
  phone         String       @unique
  bankname      String
  banknumber    String       @unique
  statusaccount String       @default("pending")
  payments      Payment[]
  lineMembers   LineMember[]
}

model Payment {
  uuid        String        @id @default(uuid()) @db.Uuid
  username    String
  paymentType PaymentType
  status      PaymentStatus @default(pending)
  createdAt   DateTime      @default(now())
  approveBy   String?       @db.Uuid
  approvedAt  DateTime?
  member      Member        @relation(fields: [username], references: [username])

  @@index([username])
  @@index([status])
  @@index([approveBy])
}

model AiSetting {
  id              String   @id @default(uuid()) @db.Uuid
  systemPrompt    String   @db.Text
  tone            String?  @db.VarChar(100)
  fallbackMessage String?  @db.Text
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
}

model AnswerPattern {
  id               String   @id @default(uuid()) @db.Uuid
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  category         String?  @db.VarChar(100)
  intentKey        String?  @db.VarChar(100)
  keywords         String[] @default([])
  questionExamples String[] @default([])
  answer           String   @db.Text
  priority         Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @db.Timestamp(6)

  vector AnswerPatternVector?
}

model CreditWallet {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  type      CreditWalletType @unique
  balance   Int              @default(0)
  usedTotal Int              @default(0)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("credit_wallets")
}

model LineMember {
  id String @id @default(uuid()) @db.Uuid

  memberId String? @db.Uuid
  member   Member? @relation(fields: [memberId], references: [uuid], onDelete: SetNull)

  lineUserId    String  @unique
  displayName   String
  pictureUrl    String?
  statusMessage String?

  lastActiveAt    DateTime?
  profileSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation  LineConversation?
  chatHistories LineChatHistory[]

  @@index([memberId])
  @@index([lastActiveAt])
}

model LineConversation {
  id              String              @id @default(uuid()) @db.Uuid
  lineMemberId    String              @unique @db.Uuid
  status          String              @default("open")
  lastMessage     String
  lastMessageType LineChatMessageType
  lastMessageAt   DateTime
  unreadCount     Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lineMember      LineMember          @relation(fields: [lineMemberId], references: [id])
  chatHistories   LineChatHistory[]

  @@index([lastMessageAt])
  @@index([status])
}

model LineChatHistory {
  id                  String              @id @default(uuid()) @db.Uuid
  conversationId      String              @db.Uuid
  lineMemberId        String              @db.Uuid
  sender              LineChatSender
  messageType         LineChatMessageType
  text                String?
  lineMessageId       String?
  replyToken          String?
  stickerPackageId    String?
  stickerId           String?
  stickerResourceType String?
  mediaUrl            String?
  postbackData        String?
  rawEvent            Json?
  sentStatus          String              @default("received")
  createdAt           DateTime            @default(now())
  conversation        LineConversation    @relation(fields: [conversationId], references: [id])
  lineMember          LineMember          @relation(fields: [lineMemberId], references: [id])

  @@index([conversationId, createdAt])
  @@index([lineMemberId])
  @@index([lineMessageId])
}

model AnswerPatternVector {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  answerPatternId String   @db.Uuid
  embedding       Unsupported("vector")
  embeddingModel  String?  @db.VarChar(100)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  answerPattern AnswerPattern @relation(fields: [answerPatternId], references: [id], onDelete: Cascade)

  @@unique([answerPatternId])
  @@index([answerPatternId])
  @@index([active])
}

model ProcessedLineWebhookEvent {
  id             String   @id @default(uuid()) @db.Uuid
  webhookEventId String   @unique
  processedAt    DateTime @default(now())

  @@index([processedAt])
}
